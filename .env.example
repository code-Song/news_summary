# 텔레그램 봇 토큰
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 텔레그램 채팅 방 ID
TELEGRAM_CHAT_ID=your_chat_id_here

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# 전송 시간 설정
DAILY_HOUR=6
DAILY_MINUTE=0
TZ=Asia/Seoul

# 가져올 뉴스 RSS 피드 목록 (쉼표로 구분)
NEWS_RSS_URLS=https://news.google.com/rss?hl=ko&gl=KR&ceid=KR:ko

# 추출할 최대 뉴스 건수
MAX_NEWS_COUNT=5
